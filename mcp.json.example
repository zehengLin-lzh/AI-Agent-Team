{
  "mcpServers": {
    "sqlite": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path", "data/memory.db"],
      "description": "SQLite database management",
      "triggers": ["database", "sql", "sqlite", "query", "table"],
      "enabled": true
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
      "description": "Local file system access",
      "triggers": ["file", "directory", "read file", "write file"],
      "enabled": true
    },
    "git": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-git"],
      "description": "Git repository operations",
      "triggers": ["git", "commit", "branch", "diff"],
      "enabled": false
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "description": "Fetch and parse web pages",
      "triggers": ["web", "fetch", "http", "url", "scrape"],
      "enabled": false
    },
    "local-db": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--directory", "/path/to/your/local-db-mcp", "python", "-m", "local_db_mcp"],
      "env": {
        "DB_CONFIG_PATH": "/path/to/your/connections.json"
      },
      "description": "Read-only database queries (MySQL, PostgreSQL, SQLite)",
      "triggers": ["database", "sql", "mysql", "postgres", "sqlite", "query", "table", "select"],
      "enabled": false
    }
  }
}

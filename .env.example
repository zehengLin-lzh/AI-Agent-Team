# Copy this file to .env and fill in the keys you want to use.
# Keys are auto-loaded by agent_team at startup. Values can be plain
# or double-quoted.

# ── Primary provider keys ────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
HF_TOKEN=
OPENROUTER_API_KEY=

# ── C2 Provider Industrialization extras ─────────────────────────────
# Optional: add _2, _3, ... suffixes to enable round-robin across multiple
# keys for the same provider. Only ANTHROPIC, OPENAI, and OPENROUTER
# currently consult the credential pool.
# ANTHROPIC_API_KEY_2=
# OPENAI_API_KEY_2=
# OPENROUTER_API_KEY_2=

# Optional: override the built-in soft rate limits ("RPM,TPM").
# Defaults: anthropic 50,40000 ; openai 500,150000 ; openrouter 200,60000
# ANTHROPIC_RATE_LIMIT=100,80000
# OPENAI_RATE_LIMIT=500,150000
# OPENROUTER_RATE_LIMIT=200,60000

# ── C3 Telegram Gateway (optional; requires `pip install -e .[gateway]`) ──
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789,987654321
